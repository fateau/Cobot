// 劇本命令
struct CircleData
{
	double	th_Final;
	double	R;
	double	center[3];
	Vector3d uNormal;
	Vector3d uStart;
};
struct IOData
{
	int			moduleInd;
	int			bitInd;
	bool		status;	// On or Off
	eLogic::e	logic;	// && or ||
};
struct MoveData
{
	double	maxV, maxA;
	double	contD;				  // 連續運動百分比，<=0 表示沒有連續
};
struct CmdMoveRaw
{
	eCmdFormat::e		format;		//pose, axis or point.
	eMovePathType::e	pathType;	//p2p, line or circle.
	eFrame::e			frame;		//Base or Tool
	BOOL				isAbs;		//abs or rel

	// --- 每次只用其中一部分 ---
	int scriptBaseIndex;
	int scriptToolIndex;
	int pointBaseIndex;						// for 記點
	int pointToolIndex;

	double	Pose    [MAX_REDUNDANCY];
	BOOL	PoseMask[MAX_REDUNDANCY];	

	double	axis    [MAX_MOTOR_PER_ROBOT];
	BOOL	axisMask[MAX_MOTOR_PER_ROBOT];

	double	Pose2[MAX_REDUNDANCY];		// for CIRCLE
	double	theta;
	int		pointBaseIndex2;
	int		pointToolIndex2;	

	MoveData mvData;
};
struct CmdMove	//transferred from CmdMoveRaw
{
	eCmdFormat::e		format;		//pose, axis or point.
	eMovePathType::e	pathType;	//p2p, line or circle.

	// --- 每次只用其中一部分 ---
	int preToolId;
	int nowToolId;

	double	startPose[MAX_REDUNDANCY];
	double    midPose[MAX_REDUNDANCY];
	double	  endPose[MAX_REDUNDANCY];

	double	startAxis[MAX_MOTOR_PER_ROBOT];
	double	  endAxis[MAX_MOTOR_PER_ROBOT];

	double	startVs[MAX_MOTOR_PER_ROBOT];
	double	  endVs[MAX_MOTOR_PER_ROBOT];

	CircleData circle;
	double	th_User; //User defined theta of the Circle-Path.
	
	double  maxVs[MAX_MOTOR_PER_ROBOT];  // 若maxV為百分比時，maxVs[i] =該軸額定轉速 * maxV/100。
	double  maxAs[MAX_MOTOR_PER_ROBOT];  // 同maxVs.

	MoveData mvData;
};

