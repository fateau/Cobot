};

struct CmdBasicInfo
{
	int lineId;					//在劇本中的行數
	int funcId;					//副程式編號
	int myMasterId;				//正在跟隨的 Master編號。 -1 表示沒有跟隨任何Master。
	eScriptCmdType::e	type;	//路徑類型
};
struct ScriptRawCmd
{
	CmdBasicInfo info;

	CmdMoveRaw	cmdMoveRaw;
	CmdIo		cmdIo;
	CmdDelay	cmdDelay;
	CmdSync		cmdSync;
};
struct ScriptPathCmd //從 ScriptCmdRaw 計算而來
{
	CmdBasicInfo info;

	CmdMove	    cmdMove;
	CmdIo		cmdIo;
	CmdDelay	cmdDelay;
	CmdSync		cmdSync;
};
struct IntpCmd //插補完的命令。可以在myCallBack直接喂給motor.
{
	CmdBasicInfo info;
	int toolIndex;

	eTargetFormat::e	format;
	double	axisDeg[MAX_MOTOR_PER_ROBOT];
	double	axisVel[MAX_MOTOR_PER_ROBOT];
	double	axisAcc[MAX_MOTOR_PER_ROBOT];

	double	Pose		 [MAX_REDUNDANCY];
	double	nowDs;			//距離起點已行走的距離
	double	nowVs;			//此瞬間的速度
	double  maxDecs;		//在降速區的最大降速度
	bool	isFinalRegion;	//是否在降速區
	bool	isContOverlap;	//是否在continue重疊區	
	bool	isParallel;		//是否為平行命令 (處理時不占用1ms)

	//type == 其他參數 io, delay, etc
	CmdIo		cmdIo;
	CmdDelay	cmdDelay;
	CmdSync		cmdSync;
};